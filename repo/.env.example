# Copy this file to .env and fill in values for your local environment.
# Never commit .env — it is listed in .gitignore.

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:changeme@localhost:5432/retail_hub

# ── Fastify server ───────────────────────────────────────────────────────────
HOST=127.0.0.1
PORT=3000

# ── Session / token signing ───────────────────────────────────────────────────
# Minimum 32 random characters. Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace_with_a_random_32_char_secret

# ── Encryption key (AES-256) ─────────────────────────────────────────────────
# Must be exactly 32 bytes (64 hex chars). Generate same way as SESSION_SECRET.
ENCRYPTION_KEY=replace_with_a_64_hex_char_encryption_key

# ── Upload storage ────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_IMAGE_SIZE_BYTES=5242880
